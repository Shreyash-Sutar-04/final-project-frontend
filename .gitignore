```gitignore
# =========================
# NODE MODULES
# =========================
node_modules/

# =========================
# BUILD FILES
# =========================
build/
dist/

# =========================
# ENV FILES
# =========================
#.env
.env.*

# =========================
# LOGS
# =========================
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================
# IDE FILES
# =========================
.idea/
.vscode/
*.iml

# =========================
# OS FILES
# =========================
.DS_Store
Thumbs.db

# =========================
# CACHE
# =========================
.cache/
.parcel-cache/

# =========================
# COVERAGE
# =========================
coverage/

# =========================
# TEMP FILES
# =========================
temp/
tmp/
```
